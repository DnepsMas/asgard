# === LLM (OpenAI 兼容) ===
OPENAI_API_KEY="sk-your-key-here"
OPENAI_BASE_URL="https://api.openai.com/v1"
AI_MODEL="gpt-4o-mini"

# === 校园网认证 (CAS) ===
MY_BUPT_USERNAME="2025xxxxxx"
MY_BUPT_PASSWORD="your-password"

# === UCloud 作业平台 ===
UCLOUD_USERNAME="2025xxxxxx"
UCLOUD_PASSWORD="your-password"
UCLOUD_TOKEN=""
UCLOUD_USER_ID=""
UCLOUD_COOKIE=""

# === 教务系统 (课表) ===
JWGL_USERNAME="2025xxxxxx"
JWGL_PASSWORD="your-password"

# === SMTP 发件 (通知邮件) ===
EMAIL_SMTP_HOST="smtp.qq.com"
EMAIL_SMTP_PORT="465"
EMAIL_USE_SSL="true"
EMAIL_USERNAME="you@qq.com"
EMAIL_PASSWORD="smtp-auth-code"
EMAIL_FROM="you@qq.com"
EMAIL_TO="you@gmail.com"

# === IMAP 收件 (任务邮件) ===
INBOUND_EMAIL_IMAP_HOST="imap.gmail.com"
INBOUND_EMAIL_IMAP_PORT="993"
INBOUND_EMAIL_USE_SSL="true"
INBOUND_EMAIL_USERNAME="you@gmail.com"
INBOUND_EMAIL_PASSWORD="imap-app-password"
INBOUND_EMAIL_ALLOWED_FROM="you@gmail.com"
